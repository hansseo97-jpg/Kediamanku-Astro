---
import "../../../styles/global.css";
import { safeJson } from "../../../lib/supabase-content.js";
import { getServiceSchemas } from "../../../lib/service-schema.js";

const { serviceSchema, faqSchema } = getServiceSchemas("Kitchen Set");
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Kitchen Set Premium | Kediamanku Design & Build</title>
    <meta name="description" content="Premium kitchen set design and build by Kediamanku with custom cabinetry, smart storage, countertop, pantry, island, and refined finishing.">
    <meta name="theme-color" content="#151716">
    <link rel="canonical" href="https://kediamanku.id/services/kitchen-set/">
    <meta property="og:title" content="Kitchen Set Premium | Kediamanku Design & Build">
    <meta property="og:description" content="Premium kitchen set design and build with custom cabinetry, smart storage, countertop, pantry, island, and refined finishing.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://kediamanku.id/services/kitchen-set/">
    <meta property="og:image" content="https://kediamanku.id/assets/images/hero-kitchen-living.webp">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" href="/kediamanku-monogram.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/services/service-detail.css">
    <link rel="stylesheet" href="/assets/site-core.css">
    <script type="application/ld+json" data-site-schema="service" data-server-rendered="true" set:html={safeJson(serviceSchema)} />
    <script type="application/ld+json" data-site-schema="faq" data-server-rendered="true" set:html={safeJson(faqSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to service detail</a>

    <header class="services-nav" aria-label="Service detail navigation">
      <a class="brand" href="../../index.html" aria-label="Back to Kediamanku homepage">
        <img decoding="async" src="/assets/images/logo-kediamanku-transparent.png" alt="Kediamanku Design Build logo" width="1121" height="274">
      </a>
      <nav aria-label="Primary navigation">
        <a href="../../index.html#home">Home</a>
        <a class="is-active" href="../index.html">Services</a>
        <a href="../../about/index.html">About</a>
        <a href="../../projects/index.html">Projects</a>
      </nav>
      <a class="nav-cta" href="../../index.html#contact">Book Consultation</a>
    </header>

    <main id="main">
      <section class="service-hero" aria-labelledby="service-title">
        <div class="container hero-layout">
          <figure class="hero-media" data-reveal data-hero-media>
            <img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Premium kitchen set design and build by Kediamanku" width="1536" height="1024">
          </figure>
          <div class="hero-title-block" data-reveal>
            <span class="service-number">01/04</span>
            <h1 id="service-title" class="hero-title">
              <span><strong>Kitchen</strong></span>
              <span class="title-line-2"><strong>Set</strong></span>
            </h1>
          </div>
          <div class="hero-summary" data-reveal>
            <span class="eyebrow">Premium custom cabinetry</span>
            <p>Custom kitchen cabinets, smart storage, countertop direction, pantry systems, island planning, and warm refined finishing for daily living.</p>
            <div class="hero-actions">
              <a class="btn btn-light" href="../../index.html#contact">Book Consultation <span aria-hidden="true">&rarr;</span></a>
              <a class="btn btn-outline" href="../../projects/index.html">View Projects <span aria-hidden="true">&nearr;</span></a>
            </div>
          </div>
          <div class="hero-side" data-reveal>
            <figure class="hero-thumb">
              <img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Warm interior detail thumbnail by Kediamanku" width="1122" height="1402">
            </figure>
            <p class="hero-note">Designed for homeowners who want a kitchen that feels calm, practical, durable, and visually composed.</p>
          </div>
        </div>
      </section>

      <section class="light-section section-pad" aria-labelledby="service-overview">
        <div class="container overview-grid">
          <div class="overview-copy" data-reveal>
            <span class="section-label">Service Overview</span>
            <h2 id="service-overview">What we design and build</h2>
            <p>We shape the kitchen around your cooking flow, storage habits, appliance needs, and preferred visual language so the result feels elegant and easy to use.</p>
            <ul class="overview-list">
              <li>Upper and lower custom cabinets</li>
              <li>Pantry, appliance tower, and island planning</li>
              <li>Countertop, backsplash, lighting, and finishing direction</li>
            </ul>
          </div>
          <figure class="overview-image" data-reveal>
            <img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Premium kitchen set custom cabinetry by Kediamanku" loading="lazy" width="1536" height="1024">
          </figure>
        </div>
      </section>

      <section class="dark-section section-pad" aria-labelledby="collection-title" data-service-feature-options data-service-category="Kitchen Set">
        <div class="container">
          <header class="section-head" data-reveal>
            <h2 id="collection-title">Featured kitchen options</h2>
            <p>Choose the pieces and finishing direction that support your cooking rhythm, hosting habits, and storage needs.</p>
          </header>
          <div class="option-grid" data-service-feature-grid>
            <article class="option-card" data-reveal>
              <img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Kitchen cabinet option by Kediamanku" loading="lazy" width="1536" height="1024">
              <div class="option-content">
                <div class="option-top"><span>01.</span><span>Cabinetry</span></div>
                <div><h3>Custom Cabinets</h3><p>Made-to-measure storage with clean panel proportion, soft-close hardware, and warm lighting options.</p></div>
              </div>
            </article>
            <article class="option-card" data-reveal>
              <img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Tall pantry and appliance storage inspiration by Kediamanku" loading="lazy" width="1122" height="1402">
              <div class="option-content">
                <div class="option-top"><span>02.</span><span>Storage</span></div>
                <div><h3>Pantry System</h3><p>Tall cabinets, appliance towers, pull-out storage, and organized zones for everyday kitchen tools.</p></div>
              </div>
            </article>
            <article class="option-card" data-reveal>
              <img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Warm material and lighting option for Kediamanku kitchen set" loading="lazy" width="1122" height="1402">
              <div class="option-content">
                <div class="option-top"><span>03.</span><span>Finishing</span></div>
                <div><h3>Countertop &amp; Light</h3><p>Material direction for countertop, backsplash, LED strips, display shelves, and premium warm ambience.</p></div>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="collection-showcase-section section-pad" aria-labelledby="all-collection-title" data-service-collection data-service-category="Kitchen Set">
        <div class="container collection-showcase">
          <h2 class="sr-only" id="all-collection-title">All kitchen collection</h2>
          <nav class="collection-showcase-tabs" aria-label="Kitchen collection styles" data-reveal data-collection-tabs>
            <span class="is-active">Modern</span>
            <span>Japandi</span>
            <span>Contemporary</span>
            <span>Minimalist</span>
            <span>Industrial</span>
          </nav>
          <div class="collection-showcase-grid" data-collection-grid>
            <article class="collection-showcase-card" data-reveal>
              <figure><img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Modern premium kitchen set collection by Kediamanku" loading="lazy" width="1536" height="1024"></figure>
              <h3>Upper &amp; Lower Cabinets</h3>
              <p>Custom cabinet planning with refined panel rhythm, storage zones, and premium finishing.</p>
            </article>
            <article class="collection-showcase-card" data-reveal>
              <figure><img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Tall pantry and kitchen storage collection by Kediamanku" loading="lazy" width="1122" height="1402"></figure>
              <h3>Pantry &amp; Appliance Tower</h3>
              <p>Tall storage, appliance placement, pull-out modules, and daily organization.</p>
            </article>
            <article class="collection-showcase-card" data-reveal>
              <figure><img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Kitchen backsplash countertop and lighting collection by Kediamanku" loading="lazy" width="1122" height="1402"></figure>
              <h3>Countertop &amp; Lighting</h3>
              <p>Backsplash, top table, LED detail, and warm visual ambience for the kitchen.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="light-section section-pad" aria-labelledby="benefits-title">
        <div class="container">
          <header class="section-head" data-reveal>
            <h2 id="benefits-title">Benefits for your kitchen</h2>
            <p>A kitchen set should look refined while making daily cooking, cleaning, and storage easier.</p>
          </header>
          <div class="benefit-grid">
            <article class="benefit-card" data-reveal><span>01</span><h3>Efficient workflow</h3><p>Layout planning supports prep, cooking, washing, and storage in a clear daily rhythm.</p></article>
            <article class="benefit-card" data-reveal><span>02</span><h3>Measured storage</h3><p>Cabinet dimensions are planned around real appliances, cookware, groceries, and habits.</p></article>
            <article class="benefit-card" data-reveal><span>03</span><h3>Premium finishing</h3><p>We guide HPL, glass, lighting, hardware, and countertop choices for a composed look.</p></article>
            <article class="benefit-card" data-reveal><span>04</span><h3>Built to last</h3><p>Production and installation are handled with detail control for long-term use.</p></article>
          </div>
        </div>
      </section>

      <section class="dark-section section-pad" aria-labelledby="service-process">
        <div class="container">
          <header class="section-head" data-reveal>
            <h2 id="service-process">How this service works</h2>
            <p>From kitchen survey to handover, each step keeps the design practical and production-ready.</p>
          </header>
          <div class="process-strip">
            <article class="process-step" data-reveal><span>01</span><h3>Consultation</h3><p>We map cooking habits, storage problems, appliance list, style, budget, and timeline.</p></article>
            <article class="process-step" data-reveal><span>02</span><h3>Survey</h3><p>We measure walls, utilities, circulation, and technical requirements for the kitchen area.</p></article>
            <article class="process-step" data-reveal><span>03</span><h3>Design &amp; quotation</h3><p>We prepare layout, material direction, visual proposal, and production estimate.</p></article>
            <article class="process-step" data-reveal><span>04</span><h3>Production</h3><p>Cabinetry is produced with material control, hardware selection, and finishing detail.</p></article>
            <article class="process-step" data-reveal><span>05</span><h3>Installation</h3><p>The kitchen is installed, checked, adjusted, and handed over for daily use.</p></article>
          </div>
        </div>
      </section>

      <section class="dark-section section-pad" aria-labelledby="gallery-title">
        <div class="container gallery-shell">
          <header class="section-head" data-reveal>
            <h2 id="gallery-title">Project gallery</h2>
            <p>Drag horizontally to explore visual references for Kediamanku kitchen set details.</p>
          </header>
          <ul class="gallery-track" aria-label="Kitchen set project gallery" data-gallery-track>
            <li class="gallery-card" data-reveal><img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Premium kitchen island and cabinet by Kediamanku" loading="lazy" width="1536" height="1024"><span class="gallery-caption">Kitchen island</span></li>
            <li class="gallery-card" data-reveal><img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Tall cabinet detail for Kediamanku kitchen storage" loading="lazy" width="1122" height="1402"><span class="gallery-caption">Tall storage</span></li>
            <li class="gallery-card" data-reveal><img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Warm lighting inspiration for Kediamanku kitchen finishing" loading="lazy" width="1122" height="1402"><span class="gallery-caption">Warm lighting</span></li>
            <li class="gallery-card" data-reveal><img decoding="async" src="/assets/images/kids-bedroom.webp" alt="Custom storage detail by Kediamanku" loading="lazy" width="1122" height="1402"><span class="gallery-caption">Custom storage</span></li>
          </ul>
        </div>
      </section>

      <section class="light-section section-pad" aria-labelledby="materials-title">
        <div class="container">
          <header class="section-head" data-reveal>
            <h2 id="materials-title">Materials &amp; finishing</h2>
            <p>Kitchen materials are selected for durability, easy maintenance, and a premium warm look.</p>
          </header>
          <div class="materials-grid">
            <article class="material-card" data-reveal><span>01</span><h3>Premium plywood</h3><p>Stable cabinet base for custom production.</p></article>
            <article class="material-card" data-reveal><span>02</span><h3>Matte HPL</h3><p>Warm neutral surface with clean maintenance.</p></article>
            <article class="material-card" data-reveal><span>03</span><h3>Quartz-look top</h3><p>Elegant countertop direction for daily kitchen use.</p></article>
            <article class="material-card" data-reveal><span>04</span><h3>Soft-close hardware</h3><p>Drawer and door system with quieter operation.</p></article>
          </div>
        </div>
      </section>

      <section class="light-section section-pad" aria-labelledby="service-faq" data-service-faq data-service-category="Kitchen Set">
        <div class="container">
          <header class="section-head" data-reveal>
            <h2 id="service-faq">Frequently Asked Questions</h2>
            <p>Quick answers before starting a kitchen set project with Kediamanku.</p>
          </header>
          <div class="faq-list" data-service-faq-list>
            <article class="faq-item is-open" data-faq-item data-reveal>
              <button class="faq-trigger" type="button" aria-expanded="true" data-faq-trigger>How long does a kitchen set project take?<span aria-hidden="true">+</span></button>
              <div class="faq-panel" data-faq-panel><div><p>Timeline depends on size, material availability, and design complexity. After survey, we provide a clearer schedule for production and installation.</p></div></div>
            </article>
            <article class="faq-item" data-faq-item data-reveal>
              <button class="faq-trigger" type="button" aria-expanded="false" data-faq-trigger>Can Kediamanku help choose materials?<span aria-hidden="true">+</span></button>
              <div class="faq-panel" aria-hidden="true" data-faq-panel><div><p>Yes. We guide material, color, hardware, lighting, and finishing choices based on your style, durability needs, and budget.</p></div></div>
            </article>
            <article class="faq-item" data-faq-item data-reveal>
              <button class="faq-trigger" type="button" aria-expanded="false" data-faq-trigger>Do you measure the kitchen area first?<span aria-hidden="true">+</span></button>
              <div class="faq-panel" aria-hidden="true" data-faq-panel><div><p>Yes. A precise survey helps us check dimensions, wall condition, utility points, circulation, and installation requirements.</p></div></div>
            </article>
          </div>
        </div>
      </section>

      <section class="final-cta">
        <div class="container final-cta-panel" data-reveal>
          <div>
            <span class="section-label">Start your kitchen set</span>
            <h2>Ready to build a refined kitchen for your home?</h2>
            <p>Share your kitchen size, style direction, storage needs, and timeline. Kediamanku will help turn it into a production-ready design.</p>
          </div>
          <div class="cta-actions">
            <a class="btn btn-light" href="../../index.html#contact">Book Consultation <span aria-hidden="true">&rarr;</span></a>
            <a class="btn btn-outline" href="../../projects/index.html">View Projects <span aria-hidden="true">&nearr;</span></a>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <img decoding="async" class="footer-logo" src="/kediamanku-white.svg" alt="Kediamanku Design Build logo" width="210" height="46">
          <p>Premium design and build interiors for kitchens, wardrobes, bedrooms, and kids rooms.</p>
        </div>
        <nav aria-label="Footer navigation">
          <h2>Navigation</h2>
          <a href="../../index.html#home">Home</a>
          <a href="../index.html">Services</a>
          <a href="../../about/index.html">About</a>
          <a href="../../projects/index.html">Projects</a>
        </nav>
        <nav aria-label="Footer service links">
          <h2>Services</h2>
          <a href="index.html">Kitchen Set Premium</a>
          <a href="../lemari-custom/index.html">Lemari Custom</a>
          <a href="../kamar-interior/index.html">Kamar Interior</a>
          <a href="../kamar-anak/index.html">Kamar Anak</a>
          <a href="../index.html">Interior Design &amp; Build</a>
        </nav>
        <div>
          <h2>Contact</h2>
          <a href="../../index.html#contact">Book Consultation</a>
          <a href="../../index.html#contact">Project Inquiry</a>
          <a href="#">Instagram</a>
          <a href="#">Social Media</a>
        </div>
      </div>
      <div class="container footer-bottom">
        <p>&copy; 2026 Kediamanku. All rights reserved.</p>
        <p>Design + Build Interior</p>
      </div>
    </footer>

    <script is:inline defer src="/supabase-config.js"></script>
    <script is:inline defer src="/services/service-detail.js"></script>
    <script is:inline defer src="/assets/site-core.js"></script>
  </body>
</html>
