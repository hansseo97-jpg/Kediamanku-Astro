---
import "../../../styles/global.css";
import { safeJson } from "../../../lib/supabase-content.js";
import { getServiceSchemas } from "../../../lib/service-schema.js";

const { serviceSchema, faqSchema } = getServiceSchemas("Kamar Interior");
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Kamar Interior | Kediamanku Design & Build</title>
    <meta name="description" content="Refined bedroom interior design and build by Kediamanku with headboard, wardrobe, side table, lighting, wall panels, and comfort-focused details.">
    <meta name="theme-color" content="#151716">
    <link rel="canonical" href="https://kediamanku.id/services/kamar-interior/">
    <meta property="og:title" content="Kamar Interior | Kediamanku Design & Build">
    <meta property="og:description" content="Refined bedroom interior design and build with headboard, wardrobe, side table, lighting, wall panels, and comfort-focused details.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://kediamanku.id/services/kamar-interior/">
    <meta property="og:image" content="https://kediamanku.id/assets/images/bedroom-interior.webp">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" href="/kediamanku-monogram.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/services/service-detail.css">
    <link rel="stylesheet" href="/assets/site-core.css">
    <script type="application/ld+json" data-site-schema="service" data-server-rendered="true" set:html={safeJson(serviceSchema)} />
    <script type="application/ld+json" data-site-schema="faq" data-server-rendered="true" set:html={safeJson(faqSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to service detail</a>
    <header class="services-nav" aria-label="Service detail navigation">
      <a class="brand" href="../../index.html" aria-label="Back to Kediamanku homepage"><img decoding="async" src="/assets/images/logo-kediamanku-transparent.png" alt="Kediamanku Design Build logo" width="1121" height="274"></a>
      <nav aria-label="Primary navigation"><a href="../../index.html#home">Home</a><a class="is-active" href="../index.html">Services</a><a href="../../about/index.html">About</a><a href="../../projects/index.html">Projects</a></nav>
      <a class="nav-cta" href="../../index.html#contact">Book Consultation</a>
    </header>

    <main id="main">
      <section class="service-hero" aria-labelledby="service-title">
        <div class="container hero-layout">
          <figure class="hero-media" data-reveal data-hero-media><img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Refined bedroom interior by Kediamanku" width="1122" height="1402"></figure>
          <div class="hero-title-block" data-reveal><span class="service-number">03/04</span><h1 id="service-title" class="hero-title"><span><strong>Kamar</strong></span><span class="title-line-2"><strong>Interior</strong></span></h1></div>
          <div class="hero-summary" data-reveal>
            <span class="eyebrow">Calm bedroom design</span>
            <p>Bedroom interiors with headboard, wardrobe integration, side tables, wall panels, lighting ambience, and comfort-focused planning.</p>
            <div class="hero-actions"><a class="btn btn-light" href="../../index.html#contact">Book Consultation <span aria-hidden="true">&rarr;</span></a><a class="btn btn-outline" href="../../projects/index.html">View Projects <span aria-hidden="true">&nearr;</span></a></div>
          </div>
          <div class="hero-side" data-reveal><figure class="hero-thumb"><img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Warm modern interior thumbnail by Kediamanku" width="1536" height="1024"></figure><p class="hero-note">Designed for a bedroom that feels restful, personal, softly lit, and functional for everyday rituals.</p></div>
        </div>
      </section>

      <section class="light-section section-pad" aria-labelledby="service-overview">
        <div class="container overview-grid">
          <div class="overview-copy" data-reveal><span class="section-label">Service Overview</span><h2 id="service-overview">What we design and build</h2><p>We compose the bedroom around rest, storage, lighting, movement, and material warmth so the space feels refined without losing practical daily function.</p><ul class="overview-list"><li>Headboard, wall panel, and bedside composition</li><li>Wardrobe, vanity, and side table integration</li><li>Lighting ambience, storage, and comfort details</li></ul></div>
          <figure class="overview-image" data-reveal><img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Bedroom interior project by Kediamanku" loading="lazy" width="1122" height="1402"></figure>
        </div>
      </section>

      <section class="dark-section section-pad" aria-labelledby="collection-title" data-service-feature-options data-service-category="Kamar Interior">
        <div class="container">
          <header class="section-head" data-reveal><h2 id="collection-title">Featured bedroom options</h2><p>Build a bedroom collection around comfort, storage, soft lighting, and elegant proportions.</p></header>
          <div class="option-grid" data-service-feature-grid>
            <article class="option-card" data-reveal><img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Custom bedroom headboard by Kediamanku" loading="lazy" width="1122" height="1402"><div class="option-content"><div class="option-top"><span>01.</span><span>Feature Wall</span></div><div><h3>Headboard Panel</h3><p>Layered headboard, wall panel, LED detail, and material rhythm for a calm room anchor.</p></div></div></article>
            <article class="option-card" data-reveal><img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Bedroom wardrobe integration by Kediamanku" loading="lazy" width="1122" height="1402"><div class="option-content"><div class="option-top"><span>02.</span><span>Storage</span></div><div><h3>Wardrobe Zone</h3><p>Built-in wardrobe planning that keeps storage visually aligned with the bedroom mood.</p></div></div></article>
            <article class="option-card" data-reveal><img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Warm lighting and side table option by Kediamanku" loading="lazy" width="1536" height="1024"><div class="option-content"><div class="option-top"><span>03.</span><span>Details</span></div><div><h3>Side Table &amp; Light</h3><p>Floating nightstands, warm lighting, soft materials, and practical bedside storage.</p></div></div></article>
          </div>
        </div>
      </section>

      <section class="collection-showcase-section section-pad" aria-labelledby="all-collection-title" data-service-collection data-service-category="Kamar Interior">
        <div class="container collection-showcase">
          <h2 class="sr-only" id="all-collection-title">All bedroom collection</h2>
          <nav class="collection-showcase-tabs" aria-label="Bedroom collection styles" data-reveal data-collection-tabs>
            <span class="is-active">Modern</span>
            <span>Calm</span>
            <span>Japandi</span>
            <span>Minimalist</span>
            <span>Hotel Feel</span>
          </nav>
          <div class="collection-showcase-grid" data-collection-grid>
            <article class="collection-showcase-card" data-reveal>
              <figure><img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Modern bedroom interior collection by Kediamanku" loading="lazy" width="1122" height="1402"></figure>
              <h3>Headboard Panel</h3>
              <p>Feature wall composition with layered panels, warm texture, and soft ambient lighting.</p>
            </article>
            <article class="collection-showcase-card" data-reveal>
              <figure><img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Bedroom wardrobe collection by Kediamanku" loading="lazy" width="1122" height="1402"></figure>
              <h3>Wardrobe Zone</h3>
              <p>Integrated wardrobe planning that keeps storage aligned with the bedroom mood.</p>
            </article>
            <article class="collection-showcase-card" data-reveal>
              <figure><img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Bedroom side table and lighting collection by Kediamanku" loading="lazy" width="1536" height="1024"></figure>
              <h3>Bedside &amp; Lighting</h3>
              <p>Floating side tables, display shelves, and warm LED details for daily comfort.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="light-section section-pad" aria-labelledby="benefits-title">
        <div class="container"><header class="section-head" data-reveal><h2 id="benefits-title">Benefits for your bedroom</h2><p>A refined bedroom supports rest, order, and daily comfort.</p></header><div class="benefit-grid"><article class="benefit-card" data-reveal><span>01</span><h3>Restful ambience</h3><p>Warm lighting and material balance create a calmer sleeping environment.</p></article><article class="benefit-card" data-reveal><span>02</span><h3>Integrated storage</h3><p>Wardrobe and furniture planning keeps the room clean and intentional.</p></article><article class="benefit-card" data-reveal><span>03</span><h3>Personal mood</h3><p>Design direction reflects your preferred texture, color, and lifestyle.</p></article><article class="benefit-card" data-reveal><span>04</span><h3>Daily function</h3><p>Bedside, lighting, circulation, and storage details are planned together.</p></article></div></div>
      </section>

      <section class="dark-section section-pad" aria-labelledby="service-process">
        <div class="container"><header class="section-head" data-reveal><h2 id="service-process">How this service works</h2><p>From room mood to production details, we keep the bedroom personal and practical.</p></header><div class="process-strip"><article class="process-step" data-reveal><span>01</span><h3>Style direction</h3><p>We discuss sleep habits, storage needs, preferred atmosphere, budget, and timeline.</p></article><article class="process-step" data-reveal><span>02</span><h3>Room survey</h3><p>We measure wall dimensions, electrical points, windows, ceiling, and circulation.</p></article><article class="process-step" data-reveal><span>03</span><h3>Design proposal</h3><p>We prepare layout, material mood, furniture details, lighting plan, and quotation.</p></article><article class="process-step" data-reveal><span>04</span><h3>Production</h3><p>Custom panels, furniture, and storage elements are produced with finishing control.</p></article><article class="process-step" data-reveal><span>05</span><h3>Installation</h3><p>Built-ins are installed, aligned, checked, and handed over with final details.</p></article></div></div>
      </section>

      <section class="dark-section section-pad" aria-labelledby="gallery-title">
        <div class="container gallery-shell"><header class="section-head" data-reveal><h2 id="gallery-title">Project gallery</h2><p>Drag horizontally to explore bedroom interior references and detail compositions.</p></header><ul class="gallery-track" aria-label="Bedroom interior gallery" data-gallery-track><li class="gallery-card" data-reveal><img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Calm bedroom interior by Kediamanku" loading="lazy" width="1122" height="1402"><span class="gallery-caption">Headboard wall</span></li><li class="gallery-card" data-reveal><img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Wardrobe detail for bedroom by Kediamanku" loading="lazy" width="1122" height="1402"><span class="gallery-caption">Wardrobe zone</span></li><li class="gallery-card" data-reveal><img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Warm interior lighting by Kediamanku" loading="lazy" width="1536" height="1024"><span class="gallery-caption">Warm lighting</span></li><li class="gallery-card" data-reveal><img decoding="async" src="/assets/images/kids-bedroom.webp" alt="Soft bedroom storage detail by Kediamanku" loading="lazy" width="1122" height="1402"><span class="gallery-caption">Storage detail</span></li></ul></div>
      </section>

      <section class="light-section section-pad" aria-labelledby="materials-title">
        <div class="container"><header class="section-head" data-reveal><h2 id="materials-title">Materials &amp; finishing</h2><p>Bedroom materials focus on warmth, tactile comfort, and lighting softness.</p></header><div class="materials-grid"><article class="material-card" data-reveal><span>01</span><h3>Wall panels</h3><p>Layered feature wall direction for a refined backdrop.</p></article><article class="material-card" data-reveal><span>02</span><h3>Matte surfaces</h3><p>Soft neutral finishing for wardrobe and furniture fronts.</p></article><article class="material-card" data-reveal><span>03</span><h3>Warm LED</h3><p>Lighting details that support rest and ambience.</p></article><article class="material-card" data-reveal><span>04</span><h3>Custom storage</h3><p>Built-in modules for daily clothing and bedroom items.</p></article></div></div>
      </section>

      <section class="light-section section-pad" aria-labelledby="service-faq" data-service-faq data-service-category="Kamar Interior">
        <div class="container"><header class="section-head" data-reveal><h2 id="service-faq">Frequently Asked Questions</h2><p>Quick answers before starting a bedroom interior project.</p></header><div class="faq-list" data-service-faq-list><article class="faq-item is-open" data-faq-item data-reveal><button class="faq-trigger" type="button" aria-expanded="true" data-faq-trigger>Can you design only one bedroom wall?<span aria-hidden="true">+</span></button><div class="faq-panel" data-faq-panel><div><p>Yes. We can focus on headboard and wall panel composition, or build a full room interior depending on your needs.</p></div></div></article><article class="faq-item" data-faq-item data-reveal><button class="faq-trigger" type="button" aria-expanded="false" data-faq-trigger>Can lighting be included?<span aria-hidden="true">+</span></button><div class="faq-panel" aria-hidden="true" data-faq-panel><div><p>Yes. We can plan warm LED details, display lighting, and practical bedside lighting direction.</p></div></div></article><article class="faq-item" data-faq-item data-reveal><button class="faq-trigger" type="button" aria-expanded="false" data-faq-trigger>Can wardrobe be included in the bedroom design?<span aria-hidden="true">+</span></button><div class="faq-panel" aria-hidden="true" data-faq-panel><div><p>Yes. Wardrobe integration is commonly included so storage and bedroom ambience feel consistent.</p></div></div></article></div></div>
      </section>

      <section class="final-cta"><div class="container final-cta-panel" data-reveal><div><span class="section-label">Start your bedroom interior</span><h2>Ready to create a calmer bedroom?</h2><p>Tell us your room size, mood direction, storage needs, and preferred finishing. Kediamanku will help translate it into a refined bedroom plan.</p></div><div class="cta-actions"><a class="btn btn-light" href="../../index.html#contact">Book Consultation <span aria-hidden="true">&rarr;</span></a><a class="btn btn-outline" href="../../projects/index.html">View Projects <span aria-hidden="true">&nearr;</span></a></div></div></section>
    </main>

    <footer class="site-footer"><div class="container footer-grid"><div><img decoding="async" class="footer-logo" src="/kediamanku-white.svg" alt="Kediamanku Design Build logo" width="210" height="46"><p>Premium design and build interiors for kitchens, wardrobes, bedrooms, and kids rooms.</p></div><nav aria-label="Footer navigation"><h2>Navigation</h2><a href="../../index.html#home">Home</a><a href="../index.html">Services</a><a href="../../about/index.html">About</a><a href="../../projects/index.html">Projects</a></nav><nav aria-label="Footer service links"><h2>Services</h2><a href="../kitchen-set/index.html">Kitchen Set Premium</a><a href="../lemari-custom/index.html">Lemari Custom</a><a href="index.html">Kamar Interior</a><a href="../kamar-anak/index.html">Kamar Anak</a><a href="../index.html">Interior Design &amp; Build</a></nav><div><h2>Contact</h2><a href="../../index.html#contact">Book Consultation</a><a href="../../index.html#contact">Project Inquiry</a><a href="#">Instagram</a><a href="#">Social Media</a></div></div><div class="container footer-bottom"><p>&copy; 2026 Kediamanku. All rights reserved.</p><p>Design + Build Interior</p></div></footer>
    <script is:inline defer src="/supabase-config.js"></script>
    <script is:inline defer src="/services/service-detail.js"></script>
    <script is:inline defer src="/assets/site-core.js"></script>
  </body>
</html>
