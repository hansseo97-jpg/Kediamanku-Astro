---
import "../../styles/global.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Testimonials | Kediamanku Premium Interior Design & Build</title>
    <meta name="description" content="Real stories from homeowners who trusted Kediamanku to design and build kitchens, wardrobes, bedrooms, and kids rooms with care, precision, and refined finishing.">
    <meta name="theme-color" content="#303A42">
    <link rel="canonical" href="https://kediamanku.id/testimonials/">
    <meta property="og:title" content="Testimonials | Kediamanku Premium Interior Design & Build">
    <meta property="og:description" content="Read real homeowner stories from Kediamanku kitchen set, wardrobe, bedroom, and kids room projects.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://kediamanku.id/testimonials/">
    <meta property="og:image" content="https://kediamanku.id/assets/images/testimonial-family.webp">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" href="/kediamanku-monogram.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/testimonials/testimonials.css">
    <link rel="stylesheet" href="/assets/site-core.css">
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to testimonials</a>

    <header class="page-nav" aria-label="Testimonials page navigation">
      <a class="brand" href="../index.html" aria-label="Back to Kediamanku homepage">
        <img decoding="async" src="/assets/images/logo-kediamanku-transparent.png" alt="Kediamanku Design Build logo" width="1121" height="274">
      </a>
      <nav aria-label="Primary navigation">
        <a href="../index.html#home">Home</a>
        <a href="../services/index.html">Services</a>
        <a href="../about/index.html">About</a>
        <a href="../projects/index.html">Projects</a>
      </nav>
      <a class="nav-cta" href="../index.html#contact">Book Consultation</a>
    </header>

    <main id="main">
      <section class="testimonial-page" aria-labelledby="testimonial-page-title">
        <header class="testimonial-hero" data-reveal>
          <span class="hero-label">Testimonials</span>
          <h1 id="testimonial-page-title">Stories from homes we refined</h1>
          <p>
            Real stories from homeowners who trusted Kediamanku to design and build kitchens, wardrobes, bedrooms, and kids rooms with care, precision, and refined finishing.
          </p>
          <div class="rating-summary" aria-label="Average rating 4.9 out of 5 from more than 100 homeowners helped">
            <strong>4.9</strong>
            <span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <em>100+ homeowners helped</em>
          </div>
        </header>

        <div class="filter-pills" role="tablist" aria-label="Filter testimonials by service" data-filters>
          <button class="is-active" type="button" role="tab" aria-selected="true" data-filter="All">All Stories</button>
          <button type="button" role="tab" aria-selected="false" data-filter="Kitchen Set">Kitchen Set</button>
          <button type="button" role="tab" aria-selected="false" data-filter="Lemari Custom">Lemari Custom</button>
          <button type="button" role="tab" aria-selected="false" data-filter="Kamar Interior">Kamar Interior</button>
          <button type="button" role="tab" aria-selected="false" data-filter="Kamar Anak">Kamar Anak</button>
        </div>

        <section class="testimonial-wall" aria-label="Homeowner testimonial stories" data-testimonial-wall>
          <div class="marquee-row row-left" data-row="0"></div>
          <div class="marquee-row row-right" data-row="1"></div>
          <div class="marquee-row row-left row-slow" data-row="2"></div>
        </section>
      </section>
    </main>

    <div class="story-modal" aria-hidden="true" data-modal>
      <button class="modal-backdrop" type="button" aria-label="Close testimonial story" data-modal-close></button>
      <article class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="modal-title" aria-describedby="modal-detail">
        <button class="modal-close" type="button" aria-label="Close modal" data-modal-close>&times;</button>
        <div class="modal-image-wrap">
          <img decoding="async" data-modal-image src="/assets/images/hero-kitchen-living.webp" alt="">
        </div>
        <div class="modal-content">
          <span class="modal-tag" data-modal-tag>Kitchen Set</span>
          <div class="modal-rating" aria-label="Five star rating">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <h2 id="modal-title" data-modal-title>Kitchen set-nya rapi dari desain sampai pemasangan</h2>
          <p id="modal-detail" data-modal-detail></p>
          <dl class="modal-meta">
            <div>
              <dt>Client</dt>
              <dd data-modal-client></dd>
            </div>
            <div>
              <dt>Location</dt>
              <dd data-modal-location></dd>
            </div>
            <div>
              <dt>Project</dt>
              <dd data-modal-project></dd>
            </div>
          </dl>
          <div class="modal-actions">
            <a href="../index.html#contact">Start Your Project</a>
            <a href="../services/index.html">View Services</a>
          </div>
        </div>
      </article>
    </div>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <img decoding="async" class="footer-logo" src="/kediamanku-white.svg" alt="Kediamanku Design Build logo" width="210" height="46">
          <p>
            Premium design and build interiors for kitchens, wardrobes, bedrooms, and kids rooms.
          </p>
        </div>

        <nav aria-label="Footer navigation">
          <h2>Navigation</h2>
          <a href="../index.html#home">Home</a>
          <a href="../services/index.html">Services</a>
          <a href="../about/index.html">About</a>
          <a href="../projects/index.html">Projects</a>
        </nav>

        <nav aria-label="Footer service links">
          <h2>Services</h2>
          <a href="../services/kitchen-set/index.html">Kitchen Set Premium</a>
          <a href="../services/lemari-custom/index.html">Lemari Custom</a>
          <a href="../services/kamar-interior/index.html">Kamar Interior</a>
          <a href="../services/kamar-anak/index.html">Kamar Anak</a>
          <a href="../services/index.html">Interior Design &amp; Build</a>
        </nav>

        <div>
          <h2>Contact</h2>
          <a href="../index.html#contact">Book Consultation</a>
          <a href="../index.html#contact">Project Inquiry</a>
          <a href="#" aria-label="Kediamanku Instagram">Instagram</a>
          <a href="#" aria-label="Kediamanku social media">Social Media</a>
        </div>
      </div>
      <div class="container footer-bottom">
        <p>&copy; 2026 Kediamanku. All rights reserved.</p>
        <p>Design + Build Interior</p>
      </div>
    </footer>

    <script is:inline defer src="/supabase-config.js"></script>
    <script is:inline defer src="/testimonials/testimonials.js"></script>
    <script is:inline defer src="/assets/site-core.js"></script>
  </body>
</html>
