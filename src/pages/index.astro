---
import "../styles/global.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Kediamanku | Premium Interior Design & Custom Furniture</title>
    <meta
      name="description"
      content="Kediamanku creates premium custom interiors for kitchen sets, wardrobes, bedrooms, and kids rooms with elegant design, precise production, and professional installation."
    >
    <meta name="keywords" content="interior design custom, jasa interior design, kitchen set premium, lemari custom, kamar anak custom, desain kamar interior, design and build interior, custom furniture rumah, interior rumah modern">
    <meta name="theme-color" content="#303940">
    <meta property="og:title" content="Kediamanku | Premium Interior Design & Custom Furniture">
    <meta property="og:description" content="Premium custom interiors for kitchens, wardrobes, bedrooms, and kids rooms - designed with elegance, built with precision.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://kediamanku.id/">
    <meta property="og:image" content="https://kediamanku.id/assets/images/hero-kitchen-living.webp">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Kediamanku | Premium Interior Design & Custom Furniture">
    <meta name="twitter:description" content="Premium custom interiors for kitchens, wardrobes, bedrooms, and kids rooms - designed with elegance, built with precision.">
    <meta name="twitter:image" content="https://kediamanku.id/assets/images/hero-kitchen-living.webp">
    <link rel="canonical" href="https://kediamanku.id/">
    <link rel="icon" href="/kediamanku-monogram.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/styles.css">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Kediamanku",
        "description": "Premium design and build interior company specializing in kitchen sets, custom wardrobes, bedroom interiors, and kids rooms.",
        "url": "https://kediamanku.id/",
        "logo": "https://kediamanku.id/assets/images/logo-kediamanku-transparent.png",
        "image": "https://kediamanku.id/assets/images/hero-kitchen-living.webp",
        "areaServed": "Indonesia",
        "priceRange": "$$$",
        "sameAs": [],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Kediamanku Interior Services",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Kitchen Set Premium",
                "url": "https://kediamanku.id/services/kitchen-set"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Lemari Custom",
                "url": "https://kediamanku.id/services/lemari-custom"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Kamar Interior",
                "url": "https://kediamanku.id/services/kamar-interior"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Kamar Anak",
                "url": "https://kediamanku.id/services/kamar-anak"
              }
            }
          ]
        }
      }
    </script>
  </head>
  <body class="home-page">
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-navbar" data-global-navbar aria-label="Primary navigation">
      <div class="navbar-container">
        <a href="/" class="navbar-logo" aria-label="Kediamanku home">
          <img src="/kediamanku-primary.svg" alt="Kediamanku" width="212" height="52">
        </a>

        <nav class="navbar-menu" aria-label="Primary navigation">
          <a class="navbar-link is-active" href="/" aria-current="page"><span>Home</span><span class="active-indicator" aria-hidden="true"></span></a>
          <div class="nav-dropdown">
            <button class="navbar-link" type="button" aria-haspopup="true" aria-expanded="false">
              <span>Services</span>
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4.2 6.2 8 10l3.8-3.8" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="dropdown-menu">
              <a href="/services/kitchen-set/">Kitchen Set</a>
              <a href="/services/lemari-custom/">Lemari Custom</a>
              <a href="/services/kamar-interior/">Kamar Interior</a>
              <a href="/services/kamar-anak/">Kamar Anak</a>
            </div>
          </div>
          <a class="navbar-link" href="/projects/"><span>Projects</span></a>
          <a class="navbar-link" href="/testimonials/"><span>Testimonials</span></a>
          <a class="navbar-link" href="/about/"><span>About</span></a>
        </nav>

        <button class="navbar-cta" type="button" data-book-consultation>Book Consultation</button>

        <button class="mobile-menu-button" type="button" aria-label="Open menu" aria-expanded="false" data-global-menu-toggle>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="navbar-mobile-panel" aria-hidden="true" data-global-mobile-panel>
        <div class="navbar-mobile-inner">
          <a class="navbar-mobile-logo" href="/" aria-label="Kediamanku home">
            <img src="/kediamanku-primary.svg" alt="Kediamanku" width="190" height="46">
          </a>
          <nav class="navbar-mobile-menu" aria-label="Mobile navigation">
            <a class="navbar-link is-active" href="/" aria-current="page"><span>Home</span><span class="active-indicator" aria-hidden="true"></span></a>
            <div class="mobile-services">
              <button type="button" data-mobile-services-toggle aria-expanded="false">
                <span>Services</span>
                <span aria-hidden="true">+</span>
              </button>
              <div class="mobile-services-panel">
                <a href="/services/kitchen-set/">Kitchen Set</a>
                <a href="/services/lemari-custom/">Lemari Custom</a>
                <a href="/services/kamar-interior/">Kamar Interior</a>
                <a href="/services/kamar-anak/">Kamar Anak</a>
              </div>
            </div>
            <a class="navbar-link" href="/projects/"><span>Projects</span></a>
            <a class="navbar-link" href="/testimonials/"><span>Testimonials</span></a>
            <a class="navbar-link" href="/about/"><span>About</span></a>
          </nav>
          <button class="navbar-mobile-cta" type="button" data-book-consultation>Book Consultation</button>
        </div>
      </div>
    </header>

    <main id="main">
      <section class="hero home-hero-section" id="home" aria-labelledby="hero-title">
        <div class="hero-container container">
          <div class="home-hero-copy">
            <p class="hero-eyebrow">Interior Design &amp; Build</p>
            <h1 id="hero-title" aria-label="Kediamanku">
              <span class="line-mask"><span>Kediamanku</span></span>
            </h1>
            <p class="hero-description">
              Kediamanku creates refined interior spaces through custom craftsmanship, spatial clarity, and modern living solutions.
            </p>
            <div class="hero-actions button-row">
              <button class="btn btn-primary" type="button" data-open-lead-modal>Book Consultation <span aria-hidden="true">&rarr;</span></button>
              <a class="btn btn-secondary" href="projects/index.html">View Projects</a>
            </div>
          </div>

          <div class="hero-partner-showcase" aria-label="Business partners trusted by Kediamanku" data-business-partners>
            <div class="partner-showcase-head">
              <span>Business Partners</span>
              <p>Selected companies and partners who trust Kediamanku for thoughtful interior solutions.</p>
            </div>

            <div class="partner-carousel" aria-hidden="false">
              <div class="partner-track" data-partner-track>
                <article class="partner-logo-card" aria-label="Takeda" aria-hidden="true">
                  <span class="partner-logo-wordmark partner-logo-takeda">Takeda</span>
                  <p>Business Partner</p>
                </article>
                <article class="partner-logo-card" aria-label="Corporate Partner" aria-hidden="true">
                  <span class="partner-logo-wordmark">Corporate Partner</span>
                  <p>Office Interior</p>
                </article>
                <article class="partner-logo-card" aria-label="Workspace Client" aria-hidden="true">
                  <span class="partner-logo-wordmark">Workspace Client</span>
                  <p>Design &amp; Build</p>
                </article>
                <article class="partner-logo-card" aria-label="Retail Partner" aria-hidden="true">
                  <span class="partner-logo-wordmark">Retail Partner</span>
                  <p>Custom Interior</p>
                </article>
                <article class="partner-logo-card" aria-label="Residential Developer" aria-hidden="true">
                  <span class="partner-logo-wordmark">Residential Developer</span>
                  <p>Interior Collaboration</p>
                </article>
                <article class="partner-logo-card" aria-label="Project Partner" aria-hidden="true">
                  <span class="partner-logo-wordmark">Project Partner</span>
                  <p>Built-in Furniture</p>
                </article>

                <article class="partner-logo-card" aria-label="Takeda">
                  <span class="partner-logo-wordmark partner-logo-takeda">Takeda</span>
                  <p>Business Partner</p>
                </article>
                <article class="partner-logo-card" aria-label="Corporate Partner">
                  <span class="partner-logo-wordmark">Corporate Partner</span>
                  <p>Office Interior</p>
                </article>
                <article class="partner-logo-card" aria-label="Workspace Client">
                  <span class="partner-logo-wordmark">Workspace Client</span>
                  <p>Design &amp; Build</p>
                </article>
                <article class="partner-logo-card" aria-label="Retail Partner">
                  <span class="partner-logo-wordmark">Retail Partner</span>
                  <p>Custom Interior</p>
                </article>
                <article class="partner-logo-card" aria-label="Residential Developer">
                  <span class="partner-logo-wordmark">Residential Developer</span>
                  <p>Interior Collaboration</p>
                </article>
                <article class="partner-logo-card" aria-label="Project Partner">
                  <span class="partner-logo-wordmark">Project Partner</span>
                  <p>Built-in Furniture</p>
                </article>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="services-showcase service-discovery section-pad" id="services" aria-labelledby="services-title">
        <div class="container service-discovery-head">
          <span class="section-kicker">Services</span>
          <h2 id="services-title">Choose the space you want to refine.</h2>
          <p>Four focused services, one clear design and build process.</p>
        </div>

        <div class="container service-discovery-grid" aria-label="Kediamanku interior services" data-home-service-grid>
          <a class="service-discovery-card" href="services/kitchen-set/index.html">
            <span>01</span>
            <img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Warm premium kitchen set by Kediamanku" width="1536" height="1024" loading="lazy">
            <h3>Kitchen Set</h3>
            <p>Custom cabinetry, storage, surfaces, and installation.</p>
          </a>

          <a class="service-discovery-card" href="services/lemari-custom/index.html">
            <span>02</span>
            <img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Custom wardrobe with integrated lighting by Kediamanku" width="1122" height="1402" loading="lazy">
            <h3>Lemari Custom</h3>
            <p>Measured wardrobe systems for calm daily routines.</p>
          </a>

          <a class="service-discovery-card" href="services/kamar-interior/index.html">
            <span>03</span>
            <img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Modern bedroom interior with refined panels by Kediamanku" width="1122" height="1402" loading="lazy">
            <h3>Kamar Interior</h3>
            <p>Bedroom interiors shaped around comfort and storage.</p>
          </a>

          <a class="service-discovery-card" href="services/kamar-anak/index.html">
            <span>04</span>
            <img decoding="async" src="/assets/images/kids-bedroom.webp" alt="Kids bedroom with custom storage and study area by Kediamanku" width="1122" height="1402" loading="lazy">
            <h3>Kamar Anak</h3>
            <p>Safe, playful, and functional rooms for growing children.</p>
          </a>
        </div>
      </section>

      <section class="brand-statement-section" aria-labelledby="statement-title">
        <span class="year-label year-left" aria-hidden="true">2016</span>

        <div class="statement-inner">
          <h2 id="statement-title" class="statement-heading" aria-label="We create timeless interior spaces focused on clarity, comfort, functionality, and modern living">
            <span class="line-mask"><span>We create timeless interior spaces</span></span>
            <span class="line-mask"><span>focused on clarity, comfort,</span></span>
            <span class="line-mask"><span>functionality, and modern living</span></span>
          </h2>
        </div>

        <span class="year-label year-right" aria-hidden="true">2026</span>
      </section>

      <section class="projects section-pad" id="projects" aria-labelledby="projects-title" data-project-section>
        <div class="container projects-editorial-head">
          <div class="projects-title-block">
            <span class="project-section-label">Our projects</span>
            <h2 id="projects-title"><span>Interior projects crafted for refined everyday living.</span></h2>
          </div>
          <a class="projects-view-all" href="projects/index.html">View all <span aria-hidden="true">&nearr;</span></a>
        </div>

        <div class="container project-carousel-shell">
          <div class="project-carousel-track" aria-label="Kediamanku selected projects" data-home-project-grid>
            <p class="home-project-empty" data-home-project-empty>No projects yet. Add real project data from the admin dashboard.</p>
          </div>
        </div>
      </section>

      <div class="project-modal" data-project-modal aria-hidden="true">
        <button class="project-modal-backdrop" type="button" aria-label="Close project detail" data-project-modal-close></button>
        <article class="project-modal-panel" role="dialog" aria-modal="true" aria-labelledby="project-modal-title" aria-describedby="project-modal-description">
          <button class="project-modal-close" type="button" aria-label="Close project detail" data-project-modal-close>&times;</button>
          <div class="project-modal-image">
            <img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="" data-project-modal-image>
          </div>
          <div class="project-modal-content">
            <span class="project-modal-label" data-project-modal-category>Premium Interior</span>
            <h3 id="project-modal-title" data-project-modal-title>Project Detail</h3>
            <p id="project-modal-description" data-project-modal-description></p>
            <div class="project-spec-grid" aria-label="Project specifications">
              <div>
                <span>Type</span>
                <strong data-project-modal-type>Modern Minimalis</strong>
              </div>
              <div>
                <span>Size</span>
                <strong data-project-modal-size>4.2m x 3.1m</strong>
              </div>
              <div>
                <span>Color</span>
                <strong data-project-modal-color>Warm taupe, ivory, charcoal</strong>
              </div>
              <div>
                <span>Location</span>
                <strong data-project-modal-location>BSD, Tangerang Selatan</strong>
              </div>
            </div>
            <div class="project-materials">
              <span>Materials & finishing</span>
              <p data-project-modal-materials></p>
            </div>
            <ul class="project-feature-list" data-project-modal-features></ul>
            <div class="project-modal-actions">
              <a href="#contact">Book Consultation</a>
              <a href="projects/index.html">View All Projects</a>
            </div>
          </div>
        </article>
      </div>

      <section class="process section-pad" id="process" aria-labelledby="process-title">
        <div class="container work-intro">
          <p class="eyebrow">How We Work</p>
          <h2 id="process-title"><span>From idea to installation</span></h2>
          <p>
            A clear design and build journey for homeowners - from first consultation, measurement,
            design proposal, production, to professional installation.
          </p>
        </div>

        <div class="container work-carousel-shell">
          <div class="work-progress" aria-hidden="true">
            <span data-work-progress-fill></span>
          </div>

          <ol class="work-track" aria-label="Kediamanku design and build process" data-work-track>
            <li class="work-card is-active" data-work-card>
              <div class="work-card-top">
                <span class="work-step" data-step="I">I</span>
                <svg class="work-icon" viewBox="0 0 72 72" aria-hidden="true">
                  <path d="M18 25.5c0-7 5.8-12.5 13-12.5h10c7.2 0 13 5.5 13 12.5v3c0 7-5.8 12.5-13 12.5h-6.5L22 51v-12.1a12.1 12.1 0 0 1-4-8.9v-4.5Z"/>
                  <path d="M28 27h16M28 34h10"/>
                </svg>
              </div>
              <div class="work-copy">
                <span class="work-kicker">First conversation</span>
                <h3>Consultation</h3>
                <p>We discuss your space, needs, lifestyle, style direction, timeline, and budget.</p>
              </div>
            </li>

            <li class="work-card" data-work-card>
              <div class="work-card-top">
                <span class="work-step" data-step="II">II</span>
                <svg class="work-icon" viewBox="0 0 72 72" aria-hidden="true">
                  <path d="M17 53 53 17"/>
                  <path d="M24 46 17 53l2-10 31-31 8 8-31 31-10 2Z"/>
                  <path d="m45 17 10 10"/>
                  <path d="M17 18h19M17 26h11"/>
                </svg>
              </div>
              <div class="work-copy">
                <span class="work-kicker">Technical check</span>
                <h3>Survey &amp; Measurement</h3>
                <p>Our team checks the space, takes precise measurements, and studies technical requirements.</p>
              </div>
            </li>

            <li class="work-card" data-work-card>
              <div class="work-card-top">
                <span class="work-step" data-step="III">III</span>
                <svg class="work-icon" viewBox="0 0 72 72" aria-hidden="true">
                  <path d="M17 17h38v38H17V17Z"/>
                  <path d="M17 31h38M31 17v38"/>
                  <path d="M24 24h3M38 39h10M38 46h7"/>
                </svg>
              </div>
              <div class="work-copy">
                <span class="work-kicker">Design direction</span>
                <h3>Design Proposal</h3>
                <p>We prepare layout direction, material options, moodboard, and quotation for your approval.</p>
              </div>
            </li>

            <li class="work-card" data-work-card>
              <div class="work-card-top">
                <span class="work-step" data-step="IV">IV</span>
                <svg class="work-icon" viewBox="0 0 72 72" aria-hidden="true">
                  <path d="M18 24h36v31H18V24Z"/>
                  <path d="M18 24 26 14h20l8 10"/>
                  <path d="M30 55V34h12v21"/>
                  <path d="M24 34h6M42 34h6"/>
                </svg>
              </div>
              <div class="work-copy">
                <span class="work-kicker">Custom build</span>
                <h3>Production</h3>
                <p>Your custom furniture is produced with careful detailing, material control, and refined finishing.</p>
              </div>
            </li>

            <li class="work-card" data-work-card>
              <div class="work-card-top">
                <span class="work-step" data-step="V">V</span>
                <svg class="work-icon" viewBox="0 0 72 72" aria-hidden="true">
                  <path d="M18 56h36"/>
                  <path d="M22 56V25h28v31"/>
                  <path d="M28 33h16M28 42h12"/>
                  <path d="m47 20 5 5 10-12"/>
                </svg>
              </div>
              <div class="work-copy">
                <span class="work-kicker">Final details</span>
                <h3>Installation &amp; Handover</h3>
                <p>Our team installs the interior on site, checks every detail, and hands over the completed space.</p>
              </div>
            </li>
          </ol>

          <div class="work-dots" aria-label="Process carousel progress">
            <button class="work-dot is-active" type="button" aria-label="Show Consultation step" data-work-dot="0"></button>
            <button class="work-dot" type="button" aria-label="Show Survey and Measurement step" data-work-dot="1"></button>
            <button class="work-dot" type="button" aria-label="Show Design Proposal step" data-work-dot="2"></button>
            <button class="work-dot" type="button" aria-label="Show Production step" data-work-dot="3"></button>
            <button class="work-dot" type="button" aria-label="Show Installation and Handover step" data-work-dot="4"></button>
          </div>
        </div>

        <div class="container work-cta-wrap">
          <a class="work-cta" href="#contact">Start Your Project <span aria-hidden="true">&rarr;</span></a>
        </div>
      </section>

      <section class="testimonials section-pad" aria-labelledby="testimonials-title" data-testimonials>
        <div class="testimonial-lines" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="container testimonials-stage">
          <div class="testimonial-float-card card-a" data-parallax="8" data-tooltip="Kitchen Set Project">
            <img decoding="async" src="/assets/images/testimonial-family.webp" alt="Homeowners smiling in a refined Kediamanku kitchen set project" loading="lazy" width="1024" height="1536">
          </div>
          <div class="testimonial-float-card card-b" data-parallax="-5" data-tooltip="Custom Wardrobe">
            <img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Custom wardrobe interior project by Kediamanku" loading="lazy" width="1122" height="1402">
          </div>
          <div class="testimonial-float-card card-c" data-parallax="6" data-tooltip="Bedroom Interior">
            <img decoding="async" src="/assets/images/testimonial-wardrobe.webp" alt="Homeowner in an elegant Kediamanku bedroom and wardrobe interior" loading="lazy" width="1024" height="1536">
          </div>
          <div class="testimonial-float-card card-d" data-parallax="-8" data-tooltip="Kids Room">
            <img decoding="async" src="/assets/images/kids-bedroom.webp" alt="Kids bedroom interior with Kediamanku custom storage" loading="lazy" width="1122" height="1402">
          </div>
          <div class="testimonial-float-card card-e" data-parallax="5" data-tooltip="Family Home">
            <img decoding="async" src="/assets/images/testimonial-kids.webp" alt="Homeowner family in a premium kids bedroom interior by Kediamanku" loading="lazy" width="1023" height="1537">
          </div>
          <div class="testimonial-float-card card-f" data-parallax="-4" data-tooltip="Kitchen Detail">
            <img decoding="async" src="/assets/images/hero-kitchen-living.webp" alt="Premium kitchen and living interior project by Kediamanku" loading="lazy" width="1536" height="1024">
          </div>
          <div class="testimonial-float-card card-g" data-parallax="7" data-tooltip="Bedroom Build">
            <img decoding="async" src="/assets/images/bedroom-interior.webp" alt="Modern bedroom interior design and build by Kediamanku" loading="lazy" width="1122" height="1402">
          </div>
          <div class="testimonial-float-card card-h" data-parallax="-6" data-tooltip="Premium Finishing">
            <img decoding="async" src="/assets/images/testimonial-family.webp" alt="Kediamanku homeowner testimonial for refined custom interiors" loading="lazy" width="1024" height="1536">
          </div>
          <div class="testimonial-float-card card-i" data-parallax="4" data-tooltip="Wardrobe Project">
            <img decoding="async" src="/assets/images/custom-wardrobe.webp" alt="Custom wardrobe design with premium finishing by Kediamanku" loading="lazy" width="1122" height="1402">
          </div>
          <div class="testimonial-float-card card-j" data-parallax="-7" data-tooltip="Calm Bedroom">
            <img decoding="async" src="/assets/images/testimonial-wardrobe.webp" alt="Happy homeowner testimonial for Kediamanku bedroom interior" loading="lazy" width="1024" height="1536">
          </div>

          <div class="testimonial-center">
            <span class="testimonial-badge">Testimonials</span>
            <h2 id="testimonials-title">Trusted by homeowners <span>for refined interiors</span></h2>
            <p>
              See how Kediamanku helps homeowners transform kitchens, wardrobes, bedrooms, and kids rooms into elegant, functional spaces.
            </p>
            <a class="testimonial-cta" href="testimonials/index.html">Read Testimonials <span aria-hidden="true">&rarr;</span></a>
          </div>
